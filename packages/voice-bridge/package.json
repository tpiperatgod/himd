    "providers/**/*",
    "prompts/**/*",
    "system-deps.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "check": "node bin/himd-voice-bridge.js --help >/dev/null && node --test test/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.0"
  }

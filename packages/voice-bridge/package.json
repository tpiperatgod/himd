{
  "name": "@himd/voice-bridge",
  "version": "0.7.0",
  "description": "Local stdio MCP server for himd voice capture, audio understanding, and TTS",
  "license": "MIT",
  "main": "index.js",
  "bin": {
    "himd-voice-bridge": "bin/himd-voice-bridge.js"
  },
  "files": [
    "bin/**/*",
    "index.js",
    "capture.js",
    "analyze.js",
    "audio-utils.js",
